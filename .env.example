# ============================================================================
# ONYX CTI PLATFORM — Environment Configuration Template
# Codename: ONYX v3.0-GENESIS
#
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in the values below with your own credentials.
#   3. NEVER commit the .env file to version control.
# ============================================================================

# --- General ---
ONYX_ENV=development
ONYX_DEBUG=true
ONYX_SECRET_KEY=<generate-a-64-char-random-hex-string>
ONYX_LOG_LEVEL=INFO
ONYX_TIMEZONE=UTC

# --- API Server ---
ONYX_API_HOST=0.0.0.0
ONYX_API_PORT=8000
ONYX_API_WORKERS=4
ONYX_API_CORS_ORIGINS=["http://localhost:3000"]
ONYX_API_RATE_LIMIT=100/minute

# --- JWT Authentication ---
ONYX_JWT_SECRET=<generate-another-64-char-random-hex-string>
ONYX_JWT_ALGORITHM=HS256
ONYX_JWT_EXPIRATION_MINUTES=1440

# --- Elasticsearch ---
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_SCHEME=http
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=<your-elasticsearch-password>
ELASTICSEARCH_IOC_INDEX=onyx-iocs
ELASTICSEARCH_THREATS_INDEX=onyx-threats
ELASTICSEARCH_AUDIT_INDEX=onyx-audit
ELASTICSEARCH_METRICS_INDEX=onyx-metrics
ELASTICSEARCH_MAX_RESULT_WINDOW=50000

# --- MongoDB ---
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=onyx_cti
MONGODB_USER=onyx_admin
MONGODB_PASSWORD=<your-mongodb-password>
MONGODB_AUTH_SOURCE=admin

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<your-redis-password>
REDIS_DB_CACHE=0
REDIS_DB_QUEUE=1
REDIS_DB_SESSIONS=2
REDIS_DB_EVENTS=3

# --- Celery ---
CELERY_BROKER_URL=redis://:<your-redis-password>@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:<your-redis-password>@localhost:6379/1
CELERY_TASK_SERIALIZER=json
CELERY_CONCURRENCY=4

# --- Tor Proxy ---
TOR_SOCKS_PORT=9050
TOR_CONTROL_PORT=9051
TOR_CONTROL_PASSWORD=<your-tor-control-password>
TOR_PRIVOXY_PORT=8118
TOR_CIRCUIT_ROTATION_SECONDS=300
TOR_MAX_CIRCUITS=5
TOR_KILL_SWITCH=false

# --- Crawler Settings ---
CRAWLER_DARKWEB_ENABLED=true
CRAWLER_CLEARWEB_ENABLED=true
CRAWLER_REQUEST_DELAY=5.0
CRAWLER_REQUEST_TIMEOUT=30
CRAWLER_MAX_CONCURRENT=3
CRAWLER_USER_AGENT_ROTATION=true
CRAWLER_SCREENSHOT_ENABLED=true

# --- NLP Engine ---
NLP_SCIBERT_MODEL=allenai/scibert_scivocab_uncased
NLP_SPACY_MODEL=en_core_web_trf
NLP_BATCH_SIZE=32
NLP_CONFIDENCE_THRESHOLD=0.65
NLP_IOC_DEFANG_ENABLED=true

# === Feed Sources / OSINT API Keys ===
# All keys below are FREE-tier. Obtain them at the URLs listed.

# abuse.ch (URLhaus, ThreatFox, MalwareBazaar) — https://auth.abuse.ch/
FEED_ABUSE_CH_ENABLED=true
URLHAUS_API_KEY=
THREATFOX_API_KEY=
MALWAREBAZAAR_API_KEY=

# AlienVault OTX — https://otx.alienvault.com/api
OTX_API_KEY=
OSINT_ALIENVAULT_OTX_KEY=

# MISP (self-hosted, optional)
FEED_MISP_URL=
FEED_MISP_API_KEY=

# CIRCL public feeds (no key required)
FEED_CIRCL_ENABLED=true

# VirusTotal — https://www.virustotal.com/gui/my-apikey
OSINT_VIRUSTOTAL_API_KEY=

# AbuseIPDB — https://www.abuseipdb.com/account/api
OSINT_ABUSEIPDB_API_KEY=

# Shodan (optional) — https://account.shodan.io/
OSINT_SHODAN_API_KEY=

# Censys (optional) — https://search.censys.io/account/api
CENSYS_API_ID=
CENSYS_API_SECRET=

# IBM X-Force (optional) — https://exchange.xforce.ibmcloud.com/settings/api
OSINT_IBM_XFORCE_KEY=
OSINT_IBM_XFORCE_PASS=

# --- Dashboard ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:8000/graphql

# ============================================================================
# AI & RAG SUBSYSTEM
# ============================================================================

# Gemini AI — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_OUTPUT_TOKENS=8192
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview

# Qdrant Vector Store — https://cloud.qdrant.io/
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=onyx_cti_iocs

# --- Guardrails ---
GUARDRAILS_ENABLED=true
GUARDRAILS_MAX_INPUT_LENGTH=4000
GUARDRAILS_MAX_OUTPUT_LENGTH=16000
