# ============================================================================
# ONYX CTI PLATFORM — Environment Configuration
# Codename: ONYX v3.1-GENESIS
# Classification: Sovereign CTI — Production-Grade
# ============================================================================

# --- General ---
ONYX_ENV=development
ONYX_DEBUG=true
ONYX_SECRET_KEY=change-me-to-a-64-char-random-hex-string
ONYX_LOG_LEVEL=INFO
ONYX_TIMEZONE=UTC

# --- API Server ---
ONYX_API_HOST=0.0.0.0
ONYX_API_PORT=8000
ONYX_API_WORKERS=4
ONYX_API_CORS_ORIGINS=["http://localhost:3000"]
ONYX_API_RATE_LIMIT=100/minute

# --- JWT Authentication ---
ONYX_JWT_SECRET=change-me-to-another-64-char-random-hex-string
ONYX_JWT_ALGORITHM=HS256
ONYX_JWT_EXPIRATION_MINUTES=1440

# --- Elasticsearch ---
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_SCHEME=http
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=onyx_elastic_secret_2026
ELASTICSEARCH_IOC_INDEX=onyx-iocs
ELASTICSEARCH_THREATS_INDEX=onyx-threats
ELASTICSEARCH_AUDIT_INDEX=onyx-audit
ELASTICSEARCH_METRICS_INDEX=onyx-metrics
ELASTICSEARCH_MAX_RESULT_WINDOW=50000

# --- MongoDB ---
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_DATABASE=onyx_cti
MONGODB_USER=onyx_admin
MONGODB_PASSWORD=onyx_mongo_secret_2026
MONGODB_AUTH_SOURCE=admin

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=onyx_redis_secret_2026
REDIS_DB_CACHE=0
REDIS_DB_QUEUE=1
REDIS_DB_SESSIONS=2
REDIS_DB_EVENTS=3

# --- Celery ---
CELERY_BROKER_URL=redis://:onyx_redis_secret_2026@redis:6379/1
CELERY_RESULT_BACKEND=redis://:onyx_redis_secret_2026@redis:6379/1
CELERY_TASK_SERIALIZER=json
CELERY_CONCURRENCY=4

# --- Tor Proxy ---
TOR_SOCKS_PORT=9050
TOR_CONTROL_PORT=9051
TOR_CONTROL_PASSWORD=onyx_tor_control_2026
TOR_PRIVOXY_PORT=8118
TOR_CIRCUIT_ROTATION_SECONDS=300
TOR_MAX_CIRCUITS=5
TOR_KILL_SWITCH=false

# --- Crawler Settings ---
CRAWLER_DARKWEB_ENABLED=true
CRAWLER_CLEARWEB_ENABLED=true
CRAWLER_REQUEST_DELAY=5.0
CRAWLER_REQUEST_TIMEOUT=30
CRAWLER_MAX_CONCURRENT=3
CRAWLER_USER_AGENT_ROTATION=true
CRAWLER_SCREENSHOT_ENABLED=true

# --- NLP Engine ---
NLP_SCIBERT_MODEL=allenai/scibert_scivocab_uncased
NLP_SPACY_MODEL=en_core_web_trf
NLP_BATCH_SIZE=32
NLP_CONFIDENCE_THRESHOLD=0.65
NLP_IOC_DEFANG_ENABLED=true

# --- Feed Sources ---
FEED_ABUSE_CH_ENABLED=true
FEED_OTX_API_KEY=
FEED_MISP_URL=
FEED_MISP_API_KEY=
FEED_CIRCL_ENABLED=true

# --- Dashboard ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:8000/graphql

# ============================================================================
# AI & RAG SUBSYSTEM
# ============================================================================

# --- Gemini AI ---
# Required: Obtain from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_OUTPUT_TOKENS=8192
GEMINI_EMBEDDING_MODEL=text-embedding-004

# --- Qdrant Vector Store ---
# Leave QDRANT_URL empty for in-memory mode (demo/dev).
# Set to a remote URL (e.g., http://qdrant:6333) for persistent production mode.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=onyx_cti_iocs

# --- LLM Security Guardrails ---
GUARDRAILS_ENABLED=true
GUARDRAILS_MAX_INPUT_LENGTH=4000
GUARDRAILS_MAX_OUTPUT_LENGTH=16000
